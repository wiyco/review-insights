{
  "name": "review-insights",
  "version": "1.0.0",
  "description": "GitHub Action to analyze PR review statistics per user with visualizations",
  "main": "dist/index.mjs",
  "scripts": {
    "typecheck": "tsc -b",
    "build": "tsc -b && rolldown -c rolldown.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "biome check . --error-on-warnings",
    "check:fix": "biome check . --error-on-warnings --write",
    "all": "pnpm run check && pnpm test && pnpm run build"
  },
  "keywords": [
    "github-action",
    "review",
    "analytics",
    "visualization"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^24.1.0",
    "@vitest/coverage-v8": "^4.1.2",
    "lefthook": "^2.1.4",
    "rolldown": "1.0.0-rc.11",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
