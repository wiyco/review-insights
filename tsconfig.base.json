{
  "compilerOptions": {
    "target": "ES2024",
    "module": "esnext",
    "lib": [
      "ES2024"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true
  }
}
